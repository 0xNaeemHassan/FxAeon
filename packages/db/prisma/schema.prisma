generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(uuid())
  telegramId      String    @unique
  privyUserId     String    @unique
  walletAddress   String    @unique
  language        String    @default("en")
  mevProtection   String    @default("off")
  slippageBps     Int       @default(50)
  referralCode    String?   @unique
  referredBy      String?
  dailyTxCount    Int       @default(0)
  dailyTxResetAt  DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  positions       Position[]
  limitOrders     LimitOrder[]
  rules           AutomationRule[]
  auditLogs       AuditLog[]
  notifications   NotificationPref?
  aiKeys          AiKey?
  transactions    Transaction[]

  @@index([telegramId])
  @@index([walletAddress])
}

model Position {
  id                String   @id @default(uuid())
  userId            String
  tokenId           String
  market            String
  side              String
  collateral        String
  debt              String
  debtRatio         Float
  leverage          Float
  liquidationPrice  Float
  healthPercent     Float
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([tokenId])
}

model LimitOrder {
  id              String   @id @default(uuid())
  userId          String
  orderHash       String   @unique
  status          String   @default("open")
  positionSide    Boolean
  orderType       Boolean
  orderSide       Boolean
  triggerPrice    String
  pool            String
  fxUSDDelta      String?
  collDelta       String?
  debtDelta       String?
  nonce           String?
  salt            String?
  deadline        DateTime?
  createdAt       DateTime @default(now())
  expiresAt       DateTime
  filledAt        DateTime?

  user            User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([orderHash])
}

model AutomationRule {
  id              String   @id @default(uuid())
  userId          String
  name            String
  type            String
  triggerSchedule String?
  triggerPrice    Json?
  triggerHealth   Json?
  actionFn        String
  actionParams    Json
  maxValueUsd     Float
  minIntervalSec  Int
  deadline        DateTime
  status          String   @default("active")
  lastRun         DateTime?
  failureCount    Int      @default(0)
  priority        Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([type])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  category  String
  data      Json
  ipHash    String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@index([category])
}

model NotificationPref {
  id                String   @id @default(uuid())
  userId            String   @unique
  tx                Boolean  @default(true)
  orders            Boolean  @default(true)
  health            Boolean  @default(true)
  rewards           Boolean  @default(false)
  governance        Boolean  @default(false)
  rules             Boolean  @default(true)
  quietHoursStart   String?
  quietHoursEnd     String?
  lastHealthAlert   DateTime?
  lastOrderAlert    DateTime?
  lastTxAlert       DateTime?
  lastRewardsAlert  DateTime?
  lastGovernanceAlert DateTime?
  lastRulesAlert    DateTime?

  user              User     @relation(fields: [userId], references: [id])
}

model AiKey {
  id          String   @id @default(uuid())
  userId      String   @unique
  encryptedKey String
  nonce       String
  provider    String   @default("surplus")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])
}

model Referral {
  id          String   @id @default(uuid())
  code        String   @unique
  referrerId  String
  refereeId   String?
  earnings    Float    @default(0)
  createdAt   DateTime @default(now())

  @@index([code])
  @@index([referrerId])
}

model TxRecord {
  id          String   @id @default(uuid())
  userId      String
  hash        String
  status      String
  type        String
  data        Json
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([hash])
  @@index([createdAt])
}

model PriceCache {
  id        String   @id @default(uuid())
  asset     String   @unique
  price     Float
  source    String
  updatedAt DateTime @updatedAt
}

model PoolCache {
  id        String   @id @default(uuid())
  pool      String   @unique
  tvl       Float
  apy       Float
  updatedAt DateTime @updatedAt
}


model Transaction {
  id        String   @id @default(cuid())
  txHash    String   @unique
  userId    String
  type      String   // open, close, adjust, deposit, withdraw
  asset     String
  amount    String
  status    String   // pending, confirmed, failed
  gasUsed   String?
  gasPrice  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user      User     @relation(fields: [userId], references: [id])
  
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}
