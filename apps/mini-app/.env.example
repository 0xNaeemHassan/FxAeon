# Privy App ID (same as bot) — required for wallet create/import in the Mini App
NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id

# Privy key-quorum (signer) id used for the revocable "bot trading" grant.
# Create it in the Privy dashboard (Wallet infrastructure -> Authorization keys)
# from the SAME authorization key the bot uses (PRIVY_AUTHORIZATION_KEY).
NEXT_PUBLIC_PRIVY_SIGNER_ID=your_privy_signer_id

# Telegram Bot Username
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=your_bot_username

# Mini App URL
NEXT_PUBLIC_MINI_APP_URL=https://your-mini-app.pages.dev

# Alchemy RPC (for client-side reads)
NEXT_PUBLIC_ALCHEMY_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY
