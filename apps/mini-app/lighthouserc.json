{
  "ci": {
    "collect": {
      "staticDistDir": "./dist",
      "url": [
        "http://localhost/index.html",
        "http://localhost/login.html"
      ],
      "numberOfRuns": 3,
      "settings": {
        "preset": "perf",
        "formFactor": "mobile",
        "throttlingMethod": "simulate",
        "throttling": {
          "rttMs": 150,
          "throughputKbps": 1638.4,
          "cpuSlowdownMultiplier": 4
        }
      }
    },
    "assert": {
      "assertions": {
        "interactive": [
          "error",
          {
            "maxNumericValue": 4000
          }
        ],
        "first-contentful-paint": [
          "warn",
          {
            "maxNumericValue": 1800
          }
        ],
        "total-blocking-time": [
          "warn",
          {
            "maxNumericValue": 300
          }
        ],
        "categories:performance": [
          "warn",
          {
            "minScore": 0.85
          }
        ]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
