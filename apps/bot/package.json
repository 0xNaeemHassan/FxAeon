{
  "name": "@fxaeon/bot",
  "version": "1.0.0",
  "scripts": {
    "build": "tsc && mkdir -p dist/i18n && cp -r src/i18n/locales dist/i18n/",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "audit": "npm audit --audit-level=moderate",
    "audit:fix": "npm audit fix"
  },
  "dependencies": {
    "@fxbot/shared": "workspace:*",
    "@fxbot/db": "workspace:*",
    "@aladdindao/fx-sdk": "1.0.5",
    "@privy-io/chains": "^0.3.0",
    "grammy": "^1.44.0",
    "@grammyjs/conversations": "^2.1.1",
    "@grammyjs/i18n": "^1.0.1",
    "@grammyjs/runner": "^2.0.1",
    "@grammyjs/transformer-throttler": "^1.2.1",
    "bullmq": "^5.78.1",
    "ioredis": "^5.4.0",
    "viem": "^2.43.1",
    "@privy-io/server-auth": "^1.12.0",
    "libsodium-wrappers": "^0.7.13",
    "openai": "^6.42.0",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "rate-limiter-flexible": "^11.2.0",
    "node-cron": "^4.2.1",
    "pino": "^9.0.0",
    "zod": "^4.4.3",
    "express": "^4.19.0",
    "ethers": "^6.9.0",
    "redis": "^6.0.0",
    "@grammyjs/menu": "^1.2.0",
    "@prisma/client": "^5.7.0",
    "prisma": "^5.7.0",
    "alchemy-sdk": "^3.0.0",
    "@privy-io/react-auth": "^3.30.0",
    "@sentry/node": "^7.100.0",
    "@sentry/profiling-node": "^7.100.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "tsx": "^4.11.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.9"
  }
}
