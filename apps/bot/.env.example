# Telegram (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_BOT_USERNAME=your_bot_username

# Privy (get from https://dashboard.privy.io)
PRIVY_APP_ID=your_privy_app_id
PRIVY_APP_SECRET=your_privy_app_secret
PRIVY_JWKS_ENDPOINT=https://auth.privy.io/api/v1/apps/YOUR_APP_ID/jwks.json

# Database (Supabase, Railway, or local)
DATABASE_URL=postgresql://user:pass@host:5432/fxbot

# Redis (Upstash or local)
REDIS_URL=redis://localhost:6379
REDIS_TOKEN=your_upstash_token_if_using_rest

# Ethereum RPC (Alchemy, Infura, or QuickNode)
ALCHEMY_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Mini App URL (Cloudflare Pages or Vercel)
MINI_APP_URL=https://your-mini-app.pages.dev

# Security (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=your_64_char_hex_key_here
PRIVY_AUTHORIZATION_KEY=your_64_char_hex_key_here

# Optional: Monitoring
SENTRY_DSN=https://xxx@yyy.ingest.sentry.io/zzz

# Optional: Rate Limiting
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW=60000

# Optional: CORS
ALLOWED_ORIGINS=https://t.me,https://your-mini-app.pages.dev

# Environment
NODE_ENV=production
PORT=8080
LOG_LEVEL=warn
DAILY_TX_CAP=50
