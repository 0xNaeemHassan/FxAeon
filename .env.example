# Copy this to .env and fill in your values
# NEVER commit .env to git

NODE_ENV=production

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Privy
PRIVY_APP_ID=your_privy_app_id
PRIVY_APP_SECRET=your_privy_app_secret

# Database
DATABASE_URL=postgresql://user:pass@host:5432/fxbot

# Redis
REDIS_URL=redis://localhost:6379
REDIS_TOKEN=your_upstash_token

# Alchemy
ALCHEMY_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Mini App
MINI_APP_URL=https://your-mini-app.pages.dev

# Security
ENCRYPTION_KEY=generate_with_openssl_rand_hex_32

# Webhook authentication (required in production)
# openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=generate_with_openssl_rand_hex_32
# From Privy dashboard -> Webhooks -> signing secret (whsec_...)
PRIVY_WEBHOOK_SECRET=your_privy_webhook_signing_secret

# Privy JWKS endpoint (dashboard -> App settings); used to verify Mini App auth tokens
PRIVY_JWKS_ENDPOINT=https://auth.privy.io/api/v1/apps/YOUR_APP_ID/jwks.json

# Privy authorization key (server signing key for the bot's session-signer quorum)
PRIVY_AUTHORIZATION_KEY=your_privy_authorization_private_key

# Ethereum RPC fallback (defaults to ALCHEMY_RPC_URL if unset)
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# HTTP port (Render injects this automatically)
PORT=8080

# Optional: admin chat for health alerts + daily SLO digest
ADMIN_TELEGRAM_CHAT_ID=

# Optional: Sentry error tracking
SENTRY_DSN=

# Optional: CoinGecko demo API key (CG-...) for /price market data
COINGECKO_API_KEY=
