# ── FxAeon backend (apps/bot) environment ─────────────────────────────────
# Copy to .env for local dev, or set these in your host's environment
# (Render injects them in production). NEVER commit a filled-in .env.
#
# The AUTHORITATIVE schema is apps/bot/src/middleware/config.ts — keep this
# file in sync with it. In production the process refuses to boot if a
# required var is missing (fail-fast); in development it warns and continues.

# ── Required ───────────────────────────────────────────────────────────────
NODE_ENV=production
TELEGRAM_BOT_TOKEN=                 # from @BotFather
DATABASE_URL=postgresql://user:pass@host:5432/fxaeon

# Required in PRODUCTION (development warns only).
# Generate each secret with: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=            # verifies the Telegram webhook (timing-safe)
ENCRYPTION_KEY=                     # at-rest encryption key (min 32 chars)
# The public URL the Telegram webhook is registered against. On Render,
# RENDER_EXTERNAL_URL is injected automatically; otherwise set WEBHOOK_URL.
WEBHOOK_URL=                        # e.g. https://fxaeon.onrender.com

# ── Privy (wallet auth + session-signer broadcast) ─────────────────────────
# Optional as a feature, but if you set one of APP_ID/APP_SECRET you must set
# both. PRIVY_AUTHORIZATION_KEY is the server signing key that lets the bot
# broadcast through the user's revocable session-signer grant.
PRIVY_APP_ID=
PRIVY_APP_SECRET=
PRIVY_AUTHORIZATION_KEY=

# ── Blockchain ─────────────────────────────────────────────────────────────
ALCHEMY_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# ── Redis (rate limiting, BullMQ queues, distributed locks) ────────────────
# A rediss:// URL (e.g. Upstash) enables the Redis-backed paths; otherwise the
# bot falls back to in-memory rate limiting.
REDIS_URL=redis://localhost:6379

# ── Optional ───────────────────────────────────────────────────────────────
PORT=8080                           # Render injects this automatically
LOG_LEVEL=info                      # trace | debug | info | warn | error | fatal
MINI_APP_URL=https://your-mini-app.pages.dev
DAILY_TX_CAP=50
ADMIN_TELEGRAM_CHAT_ID=             # admin chat for health alerts + daily SLO digest
SENTRY_DSN=                         # error tracking (disabled when unset)
COINGECKO_API_KEY=                  # /price market data (works unauthenticated too)
ETHERSCAN_API_KEY=                  # /gas live oracle (free key at https://etherscan.io/apis)
KMS_MASTER_KEY=                     # 64 hex chars; enables the KMS-backed encryption path
# HMAC key for short-TTL trade/action intents. Strongly recommended in
# production; if unset the code falls back to TELEGRAM_BOT_TOKEN.
INTENT_SECRET=

# ── Feature gates ──────────────────────────────────────────────────────────
# Signer-policy broadcast allow-list mode: enforce (default) | observe | off
SIGNER_POLICY_MODE=enforce
# Cross-chain bridge (Ethereum → Base) broadcast. Quotes always show; execution
# is opt-in. Enable ONLY after fork-verifying the OFT route and allow-listing it.
BRIDGE_EXECUTION_ENABLED=false
